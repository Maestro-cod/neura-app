# Supabase — Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret          # Settings > API > JWT Secret

# Stripe — dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_FAMILY_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...              # Required — no fallback

# Emergent LLM
EMERGENT_LLM_KEY=your-emergent-key

# CORS — comma-separated list of allowed frontend origins
# For Expo dev: use your local IP, e.g. http://192.168.1.10:8081
# For production: your app's public URL
ALLOWED_ORIGINS=http://localhost:8081,https://yourapp.com
